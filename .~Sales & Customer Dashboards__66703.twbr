              <calculation class='tableau' formula='IF SUM([Calculation_4462980169396224]) = WINDOW_MAX(SUM([Calculation_4462980169396224]))&#10;THEN SUM([Calculation_4462980169396224])&#10;ELSEIF SUM([Calculation_4462980169396224]) = WINDOW_MIN(SUM([Calculation_4462980169396224]))&#10;THEN SUM([Calculation_4462980169396224])&#10;END'>
